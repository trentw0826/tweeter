{
  "name": "tweeter-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prepare:shared": "npm --workspace tweeter-shared run compile",
    "build": "npm run prepare:shared && npm run compile",
    "test": "npm run build && node --experimental-specifier-resolution=node --test test",
    "compile": "npm run clean && tsc",
    "clean": "rimraf dist",
    "sam:build": "npm run prepare:shared && sam build --template-file template.yaml",
    "sam:deploy": "npm run sam:build && sam deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "tweeter-shared": "file:../tweeter-shared",
    "date-fns": "^3.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.9",
    "rimraf": "^5.0.5"
  }
}
